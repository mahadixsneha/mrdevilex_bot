# ╔══════════════════════════════════════════════════════════╗
# ║   .env.example — Challenge by MrDevilEx                 ║
# ║   Copy this to .env and fill in the values              ║
# ╚══════════════════════════════════════════════════════════╝

# ── Core (Required) ────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
OWNER_ID=123456789
BOT_USERNAME=YourBotUsername

# ── MongoDB Atlas (Required) ───────────────────────────────
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGO_DB_NAME=telegram_bot

# ── Webhook (Required for Render) ─────────────────────────
# Render auto-set করে — manually দিলে: https://your-app.onrender.com
WEBHOOK_URL=https://your-app-name.onrender.com

# ── Render ─────────────────────────────────────────────────
RENDER=true
PORT=10000

# ── Logging ────────────────────────────────────────────────
LOG_CHANNEL_ID=0
SUPPORT_GROUP_ID=0

# ── Dashboard API ──────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=10000
SECRET_KEY=change-this-to-a-random-secret-key
API_ADMIN_USERNAME=admin
API_ADMIN_PASSWORD=change_this_password

# ── AI Moderation ──────────────────────────────────────────
ENABLE_AI_MODERATION=true
SPAM_THRESHOLD=5
ANTI_RAID_THRESHOLD=10
ANTI_RAID_DURATION=300

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_MESSAGES=10
RATE_LIMIT_WINDOW=60

# ── Bot Settings ───────────────────────────────────────────
WARN_LIMIT=3
CAPTCHA_TIMEOUT=300
DEFAULT_LANGUAGE=en
PREMIUM_DURATION_DAYS=30
BACKUP_STORAGE_PATH=backups/
